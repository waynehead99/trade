# Copy to .env and fill in. .env is gitignored + dockerignored — never commit it.

# Paper account credentials (safe — use these while testing)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Live account credentials — only required when ALPACA_PAPER=false
PROD_ALPACA_API_KEY=
PROD_ALPACA_SECRET_KEY=

# true  = paper trading (default; recommended until you've verified the UI)
# false = LIVE trading with real money. Requires PROD_ALPACA_* above.
ALPACA_PAPER=true
